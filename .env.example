# Brand Monitoring Dashboard - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Ollama ──────────────────────────────────────────────────────────────────
# Ollama runs locally — no API key needed.
# Ensure Ollama is running before starting the app:
#   ollama serve
# Required models (pull before running):
#   ollama pull llama3.1

OLLAMA_BASE_URL=http://localhost:11434

# ── Reddit API (optional — enables Reddit as a monitoring source) ────────────
# Create an app at https://www.reddit.com/prefs/apps
# Leave blank to disable Reddit as a data source

REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=BrandMonitor/1.0 by your_username

# ── Optional overrides ───────────────────────────────────────────────────────
# OLLAMA_LLM_MODEL=llama3.1
